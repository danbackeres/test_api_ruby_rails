<h1><%= @product.name %></h1>

<p>ID do Produto: <%=@product.id%></p>
<%= @product.description %>

<%= render "inventory", product: @product %>

<%= link_to "Back", products_path %>
<% if authenticated? %>
  <%= link_to "Edit", edit_product_path(@product) %>
  <%= button_to "Destroy", @product, method: :delete, data: { turbo_confirm: "Are you sure?" } %>
<% end %>
